# ─── Better Auth ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Your app's base URL (no trailing slash)
BETTER_AUTH_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── Microsoft Azure App Registration ───────────────────────────────────────
# Used for both Microsoft sign-in (Better Auth OAuth) AND the Graph API
# (creating Azure AD users via client credentials).
#
# Azure portal setup:
#   1. App registrations → New registration
#   2. Redirect URI (Web): https://your-app.vercel.app/api/auth/callback/microsoft
#      Also add:           http://localhost:3000/api/auth/callback/microsoft
#   3. API permissions:
#        - Microsoft Graph → Delegated  → User.Read, openid, profile, email
#        - Microsoft Graph → Application → User.ReadWrite.All
#      (Grant admin consent for the application permissions)
#   4. Certificates & secrets → New client secret
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ─── Neon PostgreSQL ─────────────────────────────────────────────────────────
# Get from: console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
